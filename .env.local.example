# ============================================================
# CONFIGURAÇÃO DO PORTAL SAFRA — ROPC com conta de serviço
# Copie este arquivo para .env.local e preencha os valores
# ============================================================

# Azure App Registration
# Permissão necessária: SharePoint > user_impersonation (delegada)
# Authentication > Permitir fluxos de cliente público = Sim
SP_TENANT_ID=
SP_CLIENT_ID=
SP_CLIENT_SECRET=

# Conta de serviço M365 (usuário com acesso ao SharePoint)
SP_USERNAME=conta@dominio.onmicrosoft.com
SP_PASSWORD=

# SharePoint
SP_SITE_URL=https://SEUDOMINIO.sharepoint.com/sites/NOME-DO-SITE
SP_FOLDER_PATH=/sites/NOME-DO-SITE/Shared Documents/PASTA/SUBPASTA
